#!/usr/bin/env -S nu --stdin

def main [] {
    zellij delete-all-sessions -y

    let result = zellij list-sessions | complete

    if ($result.stdout | is-empty) or $result.exit_code != 0 {
        zellij
        return
    }

    let session = $"no(char nl)($result.stdout)new"
        | fzf --ansi --tac --reverse --cycle
        | split row ' '
        | first

    if $session == 'new' {
        zellij
    } else if $session == 'no' {
        nu -i -l
    } else if ($session | is-not-empty) {
        zellij attach $session
    }
}
