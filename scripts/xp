#!/usr/bin/env nu

def backend [] {
    $env.XDG_BACKEND | default 'wsl'
}

# 复制输入内容至剪贴板
def main [] {
    match (backend) {
        'wayland' => { wl-paste -n },
        'x11' => { xclip -sel c -o },
        _ => {
            powershell.exe Get-Clipboard
            | str trim -r
            | str replace (char crlf) (char newline)
        },
    }
}
