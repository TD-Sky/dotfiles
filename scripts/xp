#!/usr/bin/env nu

# 复制输入内容至剪贴板
def main [] {
    match $env.XDG_BACKEND? {
        'wayland' => { wl-paste -n },
        'x11' => { xclip -sel c -o },
        _ => {
            powershell.exe Get-Clipboard
            | str trim -r
            | str replace (char crlf) (char newline)
        },
    }
}
